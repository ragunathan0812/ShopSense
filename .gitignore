# ══════════════════════════════════════════════════════════════════
# ShopSense — .gitignore
# ══════════════════════════════════════════════════════════════════

# ── Raw Data (large files — do not commit) ────────────────────────
data/raw/*.csv
data/raw/*.zip

# ── Processed Data (regenerated by notebooks — optional to commit) 
# Uncomment the line below if you want to exclude processed CSVs too
# data/processed/*.csv

# ── ML Models (large binary files) ───────────────────────────────
models/*.pkl
models/*.joblib
models/*.h5

# ── Jupyter Notebook Checkpoints ─────────────────────────────────
.ipynb_checkpoints/
**/.ipynb_checkpoints/

# ── Python Cache ─────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyc

# ── Virtual Environments ──────────────────────────────────────────
.env
.venv
env/
venv/
ENV/

# ── Conda Environment ─────────────────────────────────────────────
*.conda
conda-env/

# ── OS Generated Files ────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Sensitive Config (database credentials, API keys) ────────────
*.env
config.ini
secrets.yaml

# ── IDE & Editor Files ────────────────────────────────────────────
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# ── Logs ─────────────────────────────────────────────────────────
*.log
logs/
